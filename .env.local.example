# Copy this file to .env.local and fill in your keys.

# ── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Groq (interview LLM + Whisper transcription) ────────────────────────────
# Free key at https://console.groq.com/keys
GROQ_API_KEY=

# ── Resend (support ticket emails → your inbox) ─────────────────────────────
# Sign up at https://resend.com with the inbox you want tickets in, then
# create an API key.
RESEND_API_KEY=
# Where support tickets are delivered + the From address (no hardcoded emails).
SUPPORT_INBOX=
# onboarding@resend.dev works without a verified domain; delivers to your Resend account email.
SUPPORT_FROM=Intervue.ai Support <onboarding@resend.dev>

# ── Security ────────────────────────────────────────────────────────────────
# HMAC secret signing the interview-session token that gates billable AI routes.
# Generate: `openssl rand -base64 48`. (Falls back to SUPABASE_SERVICE_ROLE_KEY
# if unset, but set a dedicated one in production.)
INTERVIEW_TOKEN_SECRET=
# Cloudflare Turnstile — lets logged-OUT users submit /api/support after a captcha.
# Both come from the same widget at dash.cloudflare.com → Turnstile. The SITE key
# is public (rendered in the browser); the SECRET key is server-side. If unset,
# only authenticated users can contact support.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Razorpay (₹ payments for Indian users) ──────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Stripe ($ payments for international users) ──────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
